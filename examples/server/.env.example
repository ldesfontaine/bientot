# examples/server/.env.example
# Copier en .env dans ce dossier et remplir.

# Password admin de la CA step-ca.
# Générer avec : openssl rand -base64 32
STEP_CA_PASSWORD=

# UID/GID hôte pour les bind-mounts de certs.
# Permet au container (qui tourne en bientot:10001 dans l'image) de lire
# les clés privées chmod 600 sur l'hôte sans relâcher les perms.
# Vérifier avec : id -u (et id -g)
HOST_UID=1000
HOST_GID=1000
