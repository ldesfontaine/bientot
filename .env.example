# Secrets pour le dev local.
# Copier en .env et remplir les valeurs.
# .env est ignoré par git.

# Password admin de la CA step-ca.
# Générer avec : openssl rand -base64 32
STEP_CA_PASSWORD=

# UID/GID host pour les bind-mounts de certs en dev.
# Permet au container (qui tourne en bientot:10001 dans l'image) de lire les
# clés privées qu'on chmod 600 sur l'hôte, sans relâcher les perms.
# Vérifier avec : id -u (et id -g)
HOST_UID=1000
HOST_GID=1000
