# ===========================================
# Bientot v2 — Variables d'environnement
# Injectées par Ansible via bientot.env.j2
# ===========================================

# ── Agent ──
BIENTOT_SERVER_URL=http://localhost:3002
BIENTOT_MACHINE_ID=dev-local
BIENTOT_TOKEN=change-me-in-production

# Push intervals
# PUSH_HOT=10s
# PUSH_WARM=1m
# PUSH_COLD=5m

# ── Server ──
# Format: machine_id:token,machine_id:token
BIENTOT_AGENTS=dev-local:change-me-in-production

# Ports (defaults)
# DASHBOARD_ADDR=0.0.0.0:3001
# AGENT_ADDR=0.0.0.0:3002

# Storage
# DB_PATH=/data/bientot.db

# Logging
# LOG_LEVEL=info

# ── Alerting ──
# ALERTS_CONFIG=config/alerts.yml
# NTFY_SERVER_URL=https://ntfy.example.com
# NTFY_TOPIC=bientot-alerts

# ── Command channel (opt-in, désactivé par défaut) ──
# COMMAND_CHANNEL=true

# ── Veille-secu (optionnel) ──
# VEILLE_CONFIG=config/veille.yml
# VEILLE_URL=http://veille-secu:8094
# VEILLE_TOKEN=

# ── Enrichment (optionnel) ──
# ENRICHMENT_CONFIG=config/enrichment.yml
# GEOIP_DB_PATH=/data/GeoLite2-City.mmdb
# MAXMIND_LICENSE=
# ABUSEIPDB_API_KEY=
# GREYNOISE_API_KEY=
# CROWDSEC_CTI_KEY=
