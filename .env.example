# ===========================================
# Bientot - Variables d'environnement
# Injectées par Ansible via bientot.env.j2
# ===========================================

# Ntfy notifications
NTFY_SERVER_URL=https://ntfy.example.com
NTFY_TOPIC=alerts

# Scraping targets
NODE_EXPORTER_PI_URL=http://100.64.0.1:9100
NODE_EXPORTER_VPS_URL=http://100.64.0.2:9100
CROWDSEC_METRICS_URL=http://100.64.0.2:6060

# Backup status
BACKUP_STATUS_DIR=/data/backup-status

# Storage (defaults internes, pas besoin de les setter en prod)
# DB_PATH=/data/metrics.db
# RETENTION_DAYS=90

# Web server (defaults internes)
# WEB_PORT=3001
# WEB_BIND=0.0.0.0
